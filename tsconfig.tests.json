{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./.test-dist",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["node"],
    "incremental": false,
    "plugins": []
  },
  "include": [
    "tests/**/*.ts",
    "src/lib/errors.ts",
    "src/lib/rate-limit.ts",
    "src/server/bookings/pricing.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".test-dist"
  ]
}
