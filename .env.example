# EventEase Environment Configuration
# Copy this file to .env and fill in the required values

# ============================================
# REQUIRED - Application must have these set
# ============================================

# MongoDB connection string
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/eventease
# For local MongoDB: mongodb://127.0.0.1:27017/eventease
MONGODB_URI=

# JWT secret for authentication (use a strong random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Optional Google Sign-In configuration
# Must be set in both server and client env spaces to enable Google authentication
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional PayPal Checkout configuration
# Set MOCK_PAYMENT_ENABLED=false and configure these values to use real PayPal checkout
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_ENVIRONMENT=sandbox

# PayPal does not support all local currencies. The app defaults to USD for PayPal orders.
# If your booking currency differs from PAYPAL_CURRENCY, set PAYPAL_EXCHANGE_RATE so the
# payable amount can be converted before the order is sent to PayPal.
PAYPAL_CURRENCY=USD
PAYPAL_EXCHANGE_RATE=

# ============================================
# OPTIONAL - Application has sensible defaults
# ============================================

# Application settings
NODE_ENV=development
APP_NAME=EventEase
APP_URL=http://localhost:3000

# Mock modes for development and viva demo
# Set to "true" to enable mock payment and email (recommended for viva)
# Set to "false" to use PayPal and SMTP
MOCK_PAYMENT_ENABLED=true
MOCK_EMAIL_ENABLED=true

# SMTP configuration (only needed if MOCK_EMAIL_ENABLED=false)
# Gmail example:
# SMTP_SERVICE=gmail
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your-google-app-password
# SMTP_FROM="EventEase <youraddress@gmail.com>"
SMTP_SERVICE=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# File upload directory for student verification documents
UPLOAD_DIR=uploads

# Optional: Google Maps Embed API key for event venue maps
# Leave empty to show venue address without embedded map
MAP_EMBED_API_KEY=

# Optional: OpenWeather API key for outdoor event forecasts
OPENWEATHER_API_KEY=
